<Window x:Class="Views.AnimalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Views"
        mc:Ignorable="d"
        FontSize="24"
        Title="Edit an animal" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Image Grid.Column="0" Grid.RowSpan="3" Margin="10" Source="{Binding Picture}" />
        <Label Grid.Row="0" Grid.Column="1" Content="Species :" HorizontalAlignment="Right" VerticalAlignment="Center" />
        <ComboBox Grid.Row="0" Grid.Column="2" ItemsSource="{Binding ListSpecies}" SelectedItem="{Binding CurrentSpecies}" Margin="10" VerticalAlignment="Center" />
        <Label Grid.Row="1" Grid.Column="1" Content="Name :" HorizontalAlignment="Right" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Name}" VerticalAlignment="Center" Margin="10" />
        <Label Grid.Row="2" Grid.Column="1" Content="Gender :" VerticalAlignment="Center" HorizontalAlignment="Right" />
        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="10" VerticalAlignment="Center" >
            <RadioButton Content="Female" IsChecked="{Binding IsFemale}" Margin="10" />
            <RadioButton Content="Male" IsChecked="{Binding IsMale}" Margin="10"  />
        </StackPanel>
        <Button Grid.Column="1" Grid.Row="3" Content="Close" Margin="10" VerticalAlignment="Center" Padding="8" Click="CloseWindow" />
    </Grid>
    
</Window>
